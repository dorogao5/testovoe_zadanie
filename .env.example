AI_BROWSER_PROVIDER=kimi
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1
AI_BROWSER_PRIMARY_MODEL=kimi-k2.6
AI_BROWSER_FAST_MODEL=kimi-k2.6
AI_BROWSER_STRONG_MODEL=kimi-k2.6
AI_BROWSER_VISION_MODEL=kimi-k2.6
AI_BROWSER_KIMI_THINKING=disabled
AI_BROWSER_KIMI_STRONG_THINKING=enabled

# Client-side LLM token throttling. Kimi defaults to a conservative 50000 TPM.
# Set 0 to disable, or lower it to leave more headroom.
# AI_BROWSER_LLM_TPM_LIMIT=50000
# AI_BROWSER_LLM_TPM_SAFETY_FACTOR=2.0

# Optional: override the session-scoped cache key. By default each run gets a
# stable key reused across all model turns in that run.
# AI_BROWSER_PROMPT_CACHE_KEY=

# Disabled by default so the agent does not use clarification questions as a normal action.
# Use handoff_to_user for real blockers such as login, CAPTCHA, or security prompts.
# AI_BROWSER_ALLOW_ASK_USER=false

AI_BROWSER_PROFILE_DIR=./profiles/default
AI_BROWSER_MAX_STEPS=50
AI_BROWSER_RECORD_VIDEO=false
AI_BROWSER_TRACE=false
